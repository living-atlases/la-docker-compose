    "bie_index": "host2",
    "images": "host2",
    "lists": "host2",
    "regions": "host2",
    "gatus": "host2",

    "solrcloud": "host3",
    "zookeeper": "host3",
    "cassandra": "host3",
    "spatial": "host3",
    "doi": "host3",
    "data_quality": "host3",
    "namematching_service": "host3",
