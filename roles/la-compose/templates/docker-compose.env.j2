# Generated from inventory at {{ ansible_date_time.iso8601 }}
# Database initialization passwords from la-test-local-passwords.ini
# DO NOT COMMIT - contains sensitive passwords

MYSQL_ROOT_PASSWORD={{ mysql_root_password }}
MYSQL_COLLECTORY_PASSWORD={{ collectory_db_password }}
MONGODB_ROOT_PASSWORD={{ mongodb_root_password }}
MONGODB_ROOT_USERNAME={{ mongodb_root_username }}
POSTGRES_PASSWORD={{ postgresql_password }}

# CAS Database Configuration (for db-cas-init script)
CAS_DB_NAME={{ cas_db_name | default('emmet') }}
CAS_DB_USERNAME={{ cas_db_username | default('cas') }}
CAS_DB_PASSWORD={{ cas_db_password | default('password') }}

# CAS Admin Account (optional - if defined, admin account will be created by db-cas-init)
{% if cas_first_admin_email is defined %}
CAS_FIRST_ADMIN_EMAIL={{ cas_first_admin_email }}
CAS_FIRST_ADMIN_BCRYPT_PASSWORD='{{ cas_first_admin_bcrypt_password | default('') }}'
CAS_FIRST_ADMIN_TEMP_AUTH_KEY={{ cas_first_admin_temp_auth_key | default('') }}
{% endif %}

# Docker Compose profiles - controls which service groups are started
COMPOSE_PROFILES={{ compose_profiles | default('full') }}

# Java Options for services (generated from inventory variables + extra_params from docker-services-desc)
# Mapping: services_enabled key → env var name prefix (for keys that differ from the docker service name)
{%- set service_env_name_map = {
  'ala_hub': 'BIOCACHE_HUB',
  'ala_bie': 'BIE_HUB'
} -%}
{% for service, java_opts in service_java_opts_dict.items() | default([]) %}
{%- set service_name = service_env_name_map.get(service, service.upper().replace('-', '_')) -%}
{%- set extra_params = (service_extra_params | default({})).get(service, []) -%}
{%- set service_version_var = service.replace('-', '_') + '_version' -%}
{%- set service_version = vars.get(service_version_var, 'develop') -%}
{%- set log_config_file = docker_services_desc.get(service, {}).get('log_config_filename', '') -%}
{%- set data_dir_name = docker_services_desc.get(service, {}).get('artifacts', service) -%}
{{ service_name }}_JAVA_OPTS={{ java_opts }}{% for param in extra_params %} -D{{ param.key }}={{ param.value }}{% endfor %} -Dhttp.agent={{ service }}/{{ service_version }}{% if log_config_file %} -Dlogging.config=/data/{{ data_dir_name }}/config/{{ log_config_file }}{% endif %}

{% endfor %}

