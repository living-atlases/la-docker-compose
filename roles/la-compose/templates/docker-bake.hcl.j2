# Docker Bake configuration for Living Atlas branding builder
# Generated by la-compose ansible role
# This file is used to build branding images independently of docker-compose
# to avoid container metadata tracking issues when recreating containers

variable "NODE_VERSION" {
  default = "{{ branding_node_version | default('18') }}"
}

variable "BUILD_SOURCE" {
  default = "{{ branding_build_source | default('local') }}"
}

{% if branding_is_git_url | default(false) %}
variable "GIT_URL" {
  default = "{{ branding_source }}"
}

variable "GIT_REF" {
  default = "{{ branding_git_ref | default('master') }}"
}
{% endif %}

target "branding" {
  dockerfile = "Dockerfile"
  context = "{{ docker_compose_data_dir }}/dockerfiles/branding"
  target = "builder-production"
  args = {
    BUILD_SOURCE = "${BUILD_SOURCE}"
    NODE_VERSION = "${NODE_VERSION}"
{% if branding_is_git_url | default(false) %}
    GIT_URL = "${GIT_URL}"
    GIT_REF = "${GIT_REF}"
{% endif %}
  }
  tags = ["branding-builder:{{ branding_version | default('latest') }}"]
  cache-to = ["type=inline"]
  platforms = ["linux/amd64"]
  output = ["type=docker"]
}
