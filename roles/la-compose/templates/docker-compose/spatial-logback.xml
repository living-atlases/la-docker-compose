<?xml version="1.0" encoding="UTF-8"?>
<!--
  Minimal Logback config for the spatial-hub / spatial-service containers.

  The 3.x images use Spring Boot + Logback, but the ala-install role only ships a legacy
  log4j.properties (and the autogenerated <SVC>_JAVA_OPTS / the role config point
  logging.config at it). Logback refuses a non-.xml file
  ("Unexpected filename extension ... Should be .xml") and the app crashes on boot. The
  compose command override sets -Dlogging.config at THIS file (a -D system property beats the
  logging.config set inside the role yml), giving plain console logging (captured by
  `docker logs`). Keep it minimal and dependency-free.
-->
<configuration>
  <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
    </encoder>
  </appender>
  <root level="INFO">
    <appender-ref ref="STDOUT"/>
  </root>
</configuration>
