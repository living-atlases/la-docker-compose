  # PostgreSQL database (for CAS and other services)
services:
  postgres:
    container_name: la_postgres
    profiles: [dbs, core-auth, app-core, full]
    # PostGIS image (drop-in superset of postgres:16) so spatial-service/geoserver/geonetwork
    # can CREATE EXTENSION postgis on their DBs (layersdb, geonetwork). Non-GIS consumers
    # (cas, collectory, image-service, doi, data-quality) are unaffected. Extensions are
    # created per-DB in init-databases.yml (not relied on from template_postgis), so this is
    # safe on volumes first initialised by the plain postgres image.
    image: postgis/postgis:16-3.4-alpine
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    # password_encryption=md5: the geonetwork:3.4.4-postgres image bundles an old libpq (<10)
    # that cannot do SCRAM, which postgres 16 uses by default -> its createdb step fails with
    # "SCRAM authentication requires libpq version 10 or above" and it crash-loops. md5 is
    # understood by every consumer (modern JDBC drivers and the old libpq). pg_hba is also
    # switched to md5 in init-databases.yml (the named volume persists scram across builds).
    command: ["postgres", "-c", "password_encryption=md5"]
    volumes:
      - la_postgres-data:/var/lib/postgresql/data
    environment:
      TZ: {{ server_tz | default('UTC') }}
      POSTGRES_DB: {{ postgres_db | default('cas') }}
      POSTGRES_USER: {{ postgres_user | default('postgres') }}
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
    expose:
      - 5432
{% if (expose_db_ports_for_init | default(false)) or (publish_db_ports_clusterwide | default(false) | bool) %}
    ports:
{% if expose_db_ports_for_init | default(false) %}
      - 127.0.0.1:5432:5432
{% endif %}
{% if publish_db_ports_clusterwide | default(false) | bool %}
      # Multi-host: reachable by remote consumers via host:port + extra_hosts.
      # Operator must firewall this to the private cluster subnet.
      - "{{ host_private_ip }}:5432:5432"
{% endif %}
{% endif %}
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
        aliases:
{% set postgres_name = postgres_db_host_address | default('postgres') %}
{% if postgres_name not in ['localhost', '127.0.0.1'] %}
          - {{ postgres_name }}
{% endif %}
          - la_postgres
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ postgres_user | default('postgres') }}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    restart: unless-stopped
