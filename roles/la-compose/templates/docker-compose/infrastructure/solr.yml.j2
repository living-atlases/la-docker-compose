  # Solr - Search engine for indexing
services:
  solr:
    image: solr:{{ solrcloud_version | default('9.4') }}
    container_name: la_solr
    profiles: [dbs, full]
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    restart: unless-stopped
    expose:
      - 8983
{% if publish_db_ports_clusterwide | default(false) | bool %}
    # Multi-host: publish the Solr port on the host private IP so remote consumers
    # (e.g. biocache-service on another host) can reach it via host:port + extra_hosts.
    # Operator must firewall this to the private cluster subnet.
    ports:
      - "{{ host_private_ip }}:8983:8983"
{% endif %}
    environment:
      TZ: {{ server_tz | default('UTC') }}
      SOLR_JAVA_MEM: "-Xms512m -Xmx2g"
      SOLR_MODE: solrcloud
      # Point Solr at the external ZK container (mirrors production where Solr
      # uses a separate ZK ensemble). Without this, Solr starts its embedded ZK
      # on :9983 and clients hitting :2181 get connection refused.
      ZK_HOST: "zookeeper:2181"
    depends_on:
      zookeeper:
        condition: service_healthy
    volumes:
      - la_solr-data:/var/solr
      # Configsets must be reachable from the long-running solr container so the
      # idempotent init-solr.yml Ansible task can run zkcli upconfig via docker
      # exec (the old one-shot solr-init never re-ran after ZK was healthy).
      - {{ docker_compose_data_dir }}/solr/init:/var/solr/init:ro
      # JTS Topology Suite jars for the biocache geohash spatial field type.
      # Mounted into server/lib/ext (the Jetty SERVER classloader, mirroring the VM
      # path ala-install uses). The spatial4j SpatialContextFactory that loads
      # JtsSpatialContextFactory runs in Solr's WebAppClassLoader, which delegates to
      # the server classloader as parent — so jars here are visible. ($SOLR_HOME/lib
      # / sharedLib is a CHILD classloader the webapp can't see, so mounting there
      # failed with NoClassDefFoundError org/locationtech/jts/geom/CoordinateSequenceFactory.)
      # Individual file mounts (not the whole dir) so the image's existing log4j jars
      # in server/lib/ext are not hidden.
      - {{ docker_compose_data_dir }}/solr/lib/jts-core-1.18.1.jar:/opt/solr/server/lib/ext/jts-core-1.18.1.jar:ro
      - {{ docker_compose_data_dir }}/solr/lib/jts-io-common-1.18.1.jar:/opt/solr/server/lib/ext/jts-io-common-1.18.1.jar:ro
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
        aliases:
          - solr
          - la_solr
    healthcheck:
      test: ["CMD", "curl", "--fail", "--silent", "http://localhost:8983/solr/admin/info/system"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 60s

