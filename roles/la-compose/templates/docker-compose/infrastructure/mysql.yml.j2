  # MySQL database (following PR #675 pattern)
services:
  mysql:
    container_name: la_mysql
    profiles: [dbs, core-auth, app-core, full]
    image: mysql:8.0-debian
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    volumes:
      - la_mysql-data:/var/lib/mysql
      - ../mysql/init:/docker-entrypoint-initdb.d:ro
    command: --default-authentication-plugin=mysql_native_password
    environment:
      TZ: {{ server_tz | default('UTC') }}
      MYSQL_ROOT_PASSWORD: ${MYSQL_ROOT_PASSWORD}
      MYSQL_USER: {{ collectory_db_user | default('collectory') }}
      MYSQL_PASSWORD: ${MYSQL_COLLECTORY_PASSWORD}
      MYSQL_DATABASE: {{ collectory_db_name | default('collectory') }}
      CAS_MYSQL_PASSWORD: ${MYSQL_ROOT_PASSWORD}
      USERDETAILS_MYSQL_PASSWORD: ${MYSQL_ROOT_PASSWORD}
      APIKEY_MYSQL_PASSWORD: ${MYSQL_ROOT_PASSWORD}
      SPECIESLIST_MYSQL_PASSWORD: ${MYSQL_ROOT_PASSWORD}
    expose:
      - 3306
{% if (expose_db_ports_for_init | default(false)) or (publish_db_ports_clusterwide | default(false) | bool) %}
    ports:
{% if expose_db_ports_for_init | default(false) %}
      - 127.0.0.1:3306:3306
{% endif %}
{% if publish_db_ports_clusterwide | default(false) | bool %}
      # Multi-host: reachable by remote consumers via host:port + extra_hosts.
      # Operator must firewall this to the private cluster subnet.
      - "{{ host_private_ip }}:3306:3306"
{% endif %}
{% endif %}
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
        aliases:
{% if collectory_db_host_address not in ['localhost', '127.0.0.1'] %}
          - {{ collectory_db_host_address }}
{% endif %}
          - la_mysql
    healthcheck:
      test: ["CMD", "mysqladmin", "ping", "-h", "localhost", "-u", "root", "-p{{ mysql_root_password }}"]
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 30s
    restart: unless-stopped


