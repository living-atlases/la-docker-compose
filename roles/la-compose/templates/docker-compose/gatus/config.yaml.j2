---
# Base gatus configuration for docker-compose deployment
# Additional *.yaml files in this directory are automatically merged by gatus
# Service endpoint configurations are generated by nginx_vhost role delegation

storage:
  type: sqlite
  path: /data/data.db

# Web UI configuration
web:
  port: {{ gatus_port | default('8080') }}

# Endpoint configurations are loaded from individual *-http.yaml files
# generated by service roles via nginx_vhost delegation