# Biocache Hub - Records search frontend
services:
  biocache-hub:
    image: {% set svc_reg = biocache_hub_registry | default(docker_registry | default('')) %}{{ svc_reg }}{% if svc_reg %}/{% endif %}ala-hub:{{ biocache_hub_version | default('latest') }}
    container_name: la_biocache-hub
    profiles: [app-core, full]
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    volumes:
      - {{ data_dir }}/ala-hub:/data/ala-hub
{% include '_i18n_volumes.yml.j2' %}
    restart: unless-stopped
    expose:
      - 8080
    environment:
      TZ: {{ server_tz | default('UTC') }}
      JAVA_OPTS: ${BIOCACHE_HUB_JAVA_OPTS}
      # Bundled application.yml references ${security.jwt.enabled} via SpEL,
      # but the upstream ala-hub-config.properties template never declares it.
      # Spring relaxed binding maps this env to the missing property.
      SECURITY_JWT_ENABLED: "{{ security_jwt_enabled | default('false') }}"
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
    healthcheck:
      test: ["CMD", "sh", "-c", "curl --fail --silent http://localhost:8080/actuator/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
