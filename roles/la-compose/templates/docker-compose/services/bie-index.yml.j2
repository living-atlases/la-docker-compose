  # BIE Index - Species web service
services:
  bie-index:
    image: {% set svc_reg = bie_index_registry | default(docker_registry | default('')) %}{{ svc_reg }}{% if svc_reg %}/{% endif %}bie-index:{{ bie_index_version | default('latest') }}
    container_name: la_bie-index
    profiles: [app-core, full]
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    volumes:
      - {{ data_dir }}/bie-index:/data/bie-index
      - {{ data_dir }}/bie-index/logs:/var/log/tomcat9
{% include '_i18n_volumes.yml.j2' %}
    restart: unless-stopped
    expose:
      - 8080
    environment:
      TZ: {{ server_tz | default('UTC') }}
      JAVA_OPTS: ${BIE_INDEX_JAVA_OPTS}
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
    healthcheck:
      # Image livingatlases/bie-index:3.x serves at root context, not /bie-index.
      # /bie-index/* returns 404; / and /admin (302) are the only live paths.
      test: ["CMD", "sh", "-c", "curl --fail --silent http://localhost:8080/ || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
