  # CAS Authentication Server
services:
  cas:
    container_name: la_cas
    profiles: [core-auth, full]
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    image: {% set svc_reg = cas_registry | default(docker_registry | default('')) %}{{ svc_reg }}{% if svc_reg %}/{% endif %}cas:{{ cas_version | default('6.5.6-3') }}
    volumes:
      - {{ data_dir }}/cas:/data/cas
      # - {{ docker_compose_data_dir }}/var-log-atlas/cas:/var/log/atlas/cas
{% include '_i18n_volumes.yml.j2' %}
    environment:
      TZ: {{ server_tz | default('UTC') }}
      JAVA_OPTS: ${CAS_JAVA_OPTS}
    expose:
      - {{ cas_port | default('9000') }}
{% if expose_db_ports_for_init | default(false) %}
    ports:
      - 127.0.0.1:{{ cas_port | default('9000') }}:{{ cas_port | default('9000') }}
{% endif %}
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
    depends_on:
      # Order-independent: wait until branding actually SERVES before CAS boots and
      # caches the commonui header/footer at startup. Otherwise CAS caches a null
      # footer and the /cas/login page renders blank. Same gate collectory/bie-hub
      # use; cross-host safe (polls the public branding URL). See
      # infrastructure/wait-for-branding.yml. (branding-init below only guarantees
      # the content volume is initialised, not that branding is serving yet.)
      wait-for-branding:
        condition: service_completed_successfully
{% if i18n.enabled and i18n.strategy == 'volume' and i18n.volume.source == 'init-container' %}
      i18n-init:
        condition: service_completed_successfully
{% endif %}
{# Gate datastore deps by co-location: a remote mysql/mongodb is not in this host's
   compose file, so depends_on would abort the up. Remote => omit, converge by retry. #}
{% if datastore_endpoints.get('mysql', {}).get('colocated', false) %}
      mysql:
        condition: service_healthy
{% endif %}
{% if datastore_endpoints.get('mongodb', {}).get('colocated', false) %}
      mongodb:
        condition: service_healthy
{% endif %}
{# co-location check: branding-init is in this host's compose when branding runs here
   via group_names OR physical_server_groups (multi-host scope). Matches the branding
   vhost/init gating; plain 'branding' in group_names misses the physical-host case. #}
{% if ('branding' in group_names) or ('branding' in (physical_server_groups | default([]))) %}
      branding-init:
        condition: service_completed_successfully
{% endif %}
      nginx:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "sh", "-c", "curl --fail --silent http://localhost:{{ cas_port | default('9000') }}/cas/actuator/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 180s
    restart: unless-stopped


