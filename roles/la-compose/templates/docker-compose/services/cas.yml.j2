  # CAS Authentication Server
services:
  cas:
    container_name: la_cas
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    image: {{ docker_registry | default('') }}{% if docker_registry %}/{% endif %}cas:{{ cas_version | default('6.5.6-3') }}
    volumes:
      - {{ data_dir }}/cas:/data/cas
      # - {{ docker_compose_data_dir }}/var-log-atlas/cas:/var/log/atlas/cas
{% include '_i18n_volumes.yml.j2' %}
    environment:
      TZ: {{ server_tz | default('UTC') }}
      JAVA_OPTS: ${CAS_JAVA_OPTS}
    expose:
      - {{ cas_port | default('9000') }}
{% if expose_db_ports_for_init | default(false) %}
    ports:
      - 127.0.0.1:{{ cas_port | default('9000') }}:{{ cas_port | default('9000') }}
{% endif %}
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
    depends_on:
{% if i18n.enabled and i18n.strategy == 'volume' and i18n.volume.source == 'init-container' %}
      i18n-init:
        condition: service_completed_successfully
{% endif %}
{% if enable_mysql | default(false) | bool %}
      mysql:
        condition: service_healthy
{% endif %}
{% if enable_mongo | default(false) | bool %}
      mongodb:
        condition: service_healthy
{% endif %}
    healthcheck:
      test: ["CMD", "sh", "-c", "curl --fail --silent http://localhost:{{ cas_port | default('9000') }}/cas/actuator/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 90s
    restart: unless-stopped


