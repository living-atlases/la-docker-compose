# Biocache Service - Records web service
services:
  biocache-service:
    image: {{ docker_registry | default('') }}{% if docker_registry %}/{% endif %}biocache-service:{{ biocache_service_version | default('latest') }}
    container_name: la_biocache-service
    profiles: [app-core, full]
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
{# depends_on can only reference services in THIS host's compose file. cassandra/
   solr may run on another host (VM model); when remote we omit the dependency and
   let restart: unless-stopped + app retry converge (swarm converge-by-retry). #}
{% set _i18n_dep = (i18n.enabled and i18n.strategy == 'volume' and i18n.volume.source == 'init-container') %}
{% set _cassandra_local = datastore_endpoints.get('cassandra', {}).get('colocated', false) %}
{% set _solr_local = datastore_endpoints.get('solr', {}).get('colocated', false) %}
{% if _i18n_dep or _cassandra_local or _solr_local %}
    depends_on:
{% if _i18n_dep %}
      i18n-init:
        condition: service_completed_successfully
{% endif %}
{% if _cassandra_local %}
      cassandra:
        condition: service_healthy
      cassandra-load-keyspace:
        condition: service_completed_successfully
{% endif %}
{% if _solr_local %}
      solr:
        condition: service_healthy
{% endif %}
{% endif %}
    volumes:
      # Host /data/biocache is mounted at TWO container paths because the
      # image's hardcoded -Dlogging.config expects /data/biocache-service/,
      # while the bundled application.properties imports config from
      # /data/biocache/config/biocache-config.properties (Spring ConfigData).
      # Without /data/biocache, cassandra.hosts silently defaults to localhost.
      - {{ data_dir }}/biocache:/data/biocache
      - {{ data_dir }}/biocache:/data/biocache-service
{% include '_i18n_volumes.yml.j2' %}
    restart: unless-stopped
    expose:
      - 8080
    environment:
      TZ: {{ server_tz | default('UTC') }}
      JAVA_OPTS: ${BIOCACHE_SERVICE_JAVA_OPTS}
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
    healthcheck:
      # /actuator/health da 503 (DOWN, diagnóstico aparte). /index/fields es ligero
      # y prueba liveness + conectividad con Solr (200 cuando la colección biocache existe).
      test: ["CMD", "sh", "-c", "curl --fail --silent http://localhost:8080/index/fields || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
