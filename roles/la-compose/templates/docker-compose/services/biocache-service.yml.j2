# Biocache Service - Records web service
services:
  biocache-service:
    image: {{ docker_registry | default('') }}{% if docker_registry %}/{% endif %}biocache-service:{{ biocache_service_version | default('latest') }}
    container_name: la_biocache-service
    profiles: [app-core, full]
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    volumes:
      # Host /data/biocache is mounted at TWO container paths because the
      # image's hardcoded -Dlogging.config expects /data/biocache-service/,
      # while the bundled application.properties imports config from
      # /data/biocache/config/biocache-config.properties (Spring ConfigData).
      # Without /data/biocache, cassandra.hosts silently defaults to localhost.
      - {{ data_dir }}/biocache:/data/biocache
      - {{ data_dir }}/biocache:/data/biocache-service
{% include '_i18n_volumes.yml.j2' %}
    restart: unless-stopped
    expose:
      - 8080
    environment:
      TZ: {{ server_tz | default('UTC') }}
      JAVA_OPTS: ${BIOCACHE_SERVICE_JAVA_OPTS}
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
    healthcheck:
      test: ["CMD", "sh", "-c", "curl --fail --silent http://localhost:8080/ws/actuator/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
