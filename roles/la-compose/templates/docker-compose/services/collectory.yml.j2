services:
  # Collectory service
  collectory:
    container_name: la_collectory
    profiles: [app-core, full]
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    image: {% set svc_reg = collectory_registry | default(docker_registry | default('')) %}{{ svc_reg }}{% if svc_reg %}/{% endif %}collectory:{{ collectory_version | default('latest') }}
    volumes:
      - {{ data_dir }}/collectory:/data/collectory
      # Bind-mount /var/log/tomcat9 because the bundled logback.xml hard-sets
      # LOG_DIR via <variable> (overriding env vars). Mounting the host logs
      # dir lets logback write where it expects.
      - {{ data_dir }}/collectory/logs:/var/log/tomcat9
{% include '_i18n_volumes.yml.j2' %}
    environment:
      TZ: {{ server_tz | default('UTC') }}
      JAVA_OPTS: ${COLLECTORY_JAVA_OPTS}
    expose:
      - 8080
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
{# depends_on only resolves services in THIS host's compose. Gate each dep by
   co-location (mysql remote => omit; cas* already per-host via services_enabled)
   and wrap the whole block so it is never emitted empty. #}
{% set _i18n_dep = (i18n.enabled and i18n.strategy == 'volume' and i18n.volume.source == 'init-container') %}
{% set _mysql_local = datastore_endpoints.get('mysql', {}).get('colocated', false) %}
{% set _cas_local = ('cas' in services_enabled) %}
    depends_on:
      # Order-independent: wait until branding actually serves before collectory boots
      # and caches the commonui header/footer (else g:message NPE -> 500). See
      # infrastructure/wait-for-branding.yml.
      wait-for-branding:
        condition: service_completed_successfully
{% if _i18n_dep %}
      i18n-init:
        condition: service_completed_successfully
{% endif %}
{% if _mysql_local %}
      mysql:
        condition: service_healthy
{% endif %}
{% if _cas_local %}
      cas:
        condition: service_healthy
      userdetails:
        condition: service_healthy
      apikey:
        condition: service_healthy
      cas-management:
        condition: service_healthy
{% endif %}
    healthcheck:
      # Sondea la home branded (/): la salud debe reflejar si el servicio SIRVE páginas.
      # Los hubs ala-bootstrap3 cachean el header de branding al arrancar; si branding no
      # servía aún, cachean null y toda página da 500 (NPE <g:message> _main.gsp:107). Con /
      # el hub sale `unhealthy` (no un falso `healthy`) y el converge de wait-for-health.sh lo
      # reinicia -> re-fetch con branding up -> 200. Verificado: restart con branding up -> 200.
      test: ["CMD", "sh", "-c", "curl --fail --silent http://localhost:8080/ || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
    restart: unless-stopped

