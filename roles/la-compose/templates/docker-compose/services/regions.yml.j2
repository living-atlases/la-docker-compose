# Regions - regional data frontend
services:
  regions:
    image: {% set svc_reg = regions_registry | default(docker_registry | default('')) %}{{ svc_reg }}{% if svc_reg %}/{% endif %}regions:{{ regions_version | default('latest') }}
    container_name: {{ regions_docker_host | default('la_regions') }}
    profiles: [app-core, full]
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
{% if 'collectory' in services_enabled or 'ala_bie' in services_enabled %}
    depends_on:
      # Order-independent branding readiness gate (commonui header/footer); cross-host safe.
      wait-for-branding:
        condition: service_completed_successfully
{% endif %}
    volumes:
      # Role (ala-install/regions) writes config to {{ data_dir }}/regions/config; the image
      # reads /data/regions/config (artifact name = regions). config-dir-ensure recurse-chowns it.
      - {{ data_dir }}/regions/config:/data/regions/config
      # logback.xml writes to /var/log/tomcat9/regions.log; the image has no /var/log/tomcat9
      # (not writable by uid 1000) so bind a host dir (created uid 1000 by config-dir-ensure).
      - {{ data_dir }}/regions/logs:/var/log/tomcat9
{% include '_i18n_volumes.yml.j2' %}
    restart: unless-stopped
    expose:
      - {{ regions_port | default('8080') }}
    environment:
      TZ: {{ server_tz | default('UTC') }}
      JAVA_OPTS: ${REGIONS_JAVA_OPTS}
    # The baked image CMD hardcodes spring.config.name=application,application-local-config and
    # ignores $JAVA_OPTS, so the role-generated regions-config.properties is never loaded. Override
    # the command to honor JAVA_OPTS and add the regions-config name (mirrors doi/logger/image).
    command: ["/bin/sh", "-c", "exec java $$JAVA_OPTS -Xss512k -Djava.awt.headless=true -Dspring.config.additional-location=/data/regions/config/ -Dspring.config.name=application,application-local-config,regions-config -jar /opt/atlas/$$APP_ARTIFACT/app.war"]
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
    healthcheck:
      # Spring Boot WAR (WarLauncher) serves the regions UI at the embedded context root (no
      # server context-path). Accept 2xx/3xx/4xx (server up) and fail on refused/5xx.
      test: ["CMD-SHELL", "curl -s -o /dev/null -w '%{http_code}' http://localhost:{{ regions_port | default('8080') }}/ | grep -qvE '^(000|5)'"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 90s
