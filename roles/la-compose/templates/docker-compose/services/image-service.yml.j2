# Image Service
services:
  image-service:
    image: {{ docker_registry | default('') }}{% if docker_registry %}/{% endif %}image-service:{{ image_service_version | default('latest') }}
    container_name: {{ image_service_docker_host | default('la_image-service') }}
    profiles: [app-core, full]
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    restart: unless-stopped
    expose:
      - {{ image_service_port | default('8080') }}
    environment:
      TZ: {{ server_tz | default('UTC') }}
      JAVA_OPTS: {{ image_service_java_opts | default('-Xmx1g -Xms1g') }}
      # Spring Boot auto-configures an Elasticsearch RestClient used ONLY by
      # ElasticsearchRestClientHealthIndicator. Without spring.elasticsearch.uris it
      # defaults to localhost:9200 -> ConnectException in Docker (ES is a separate
      # container) -> /actuator/health returns 503 -> the container is marked unhealthy
      # though the app's OWN ES client (elasticsearch.hosts) reaches elasticsearch:9200
      # fine. Point Spring's client at the same ES so the indicator passes. Docker-only:
      # on VMs ES is localhost and the Spring default already works (ala-install untouched).
      SPRING_ELASTICSEARCH_URIS: "{{ image_service_elasticsearch_uri | default('http://elasticsearch:9200') }}"
    # Image CMD hardcodes -Dlogging.config=.../logback.groovy, which modern Logback
    # (>=1.3, bundled in 4.1.0) rejects. Override to point at logback.xml and honor JAVA_OPTS.
    command: ["/bin/sh", "-c", "exec java $$JAVA_OPTS -Djava.awt.headless=true -Dlogging.config=/data/image-service/config/logback.xml -Dspring.config.additional-location=/data/image-service/config/ -Dspring.config.name=application,application-local-config,image-service-config -jar /opt/atlas/$$APP_ARTIFACT/app.jar"]
    volumes:
      - {{ data_dir }}/image-service/config:/data/image-service/config
      - {{ data_dir }}/image-service/store:/data/image-service/store
      - {{ data_dir }}/image-service/incoming:/data/image-service/incoming
      - {{ data_dir }}/image-service/exports:/data/image-service/exports
      - {{ data_dir }}/image-service/bin:/data/image-service/bin
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:{{ image_service_port | default('8080') }}{{ image_service_context_path | default('') }}/actuator/health"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
