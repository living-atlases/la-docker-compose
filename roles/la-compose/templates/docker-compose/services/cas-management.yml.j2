# CAS Management Service
services:
  cas-management:
    container_name: la_cas-management
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    image: {{ docker_registry | default('') }}{% if docker_registry %}/{% endif %}cas-management:{{ cas_management_version | default('latest') }}
    volumes:
      - {{ data_dir }}/cas-management:/data/cas-management
      # - {{ docker_compose_data_dir }}/var-log-atlas/cas-management:/var/log/atlas/cas-management
{% include '_i18n_volumes.yml.j2' %}
    environment:
      TZ: {{ server_tz | default('UTC') }}
      JAVA_OPTS: ${CAS_MANAGEMENT_JAVA_OPTS}
    expose:
      - {{ cas_management_port | default('8070') }}
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
    depends_on:
{% if i18n.enabled and i18n.strategy == 'volume' and i18n.volume.source == 'init-container' %}
      i18n-init:
        condition: service_completed_successfully
{% endif %}
{% if enable_mysql | default(false) | bool %}
      mysql:
        condition: service_healthy
{% endif %}
{% if enable_mongo | default(false) | bool %}
      mongodb:
        condition: service_healthy
{% endif %}
      cas:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "sh", "-c", "curl --fail --silent http://localhost:{{ cas_management_port | default('8070') }}/cas-management/actuator/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 90s
    restart: unless-stopped


