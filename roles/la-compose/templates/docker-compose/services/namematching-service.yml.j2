services:
   namematching-service:
     container_name: la_namematching_service
     profiles: [app-core, full]
     image: {% set svc_reg = namematching_registry | default(docker_registry | default('')) %}{{ svc_reg }}{% if svc_reg %}/{% endif %}ala-namematching-server:{{ namematching_docker_tag | default('latest') }}
     ports:
       - "{{ namematching_service_port }}:9179"
       - "{{ namematching_admin_port }}:9180"
     environment:
       - JAVA_OPTS=-Xmx2g -Xms1g
       - NAMEMATCHING_SERVICE_JAVA_OPTS=-Xmx2g -Xms1g
     volumes:
       - "{{ data_dir }}/lucene/namematching-nm:/data/lucene/namematching-nm:ro"
       - "{{ data_dir }}/ala-namematching-service/config:/data/ala-namematching-server/config:ro"
     networks:
       default: {}
       {{ docker_network | default('internal') }}:
     healthcheck:
       test: ["CMD", "curl", "--fail", "--silent", "http://localhost:9180/healthcheck"]
       interval: 30s
       timeout: 10s
       retries: 3
       start_period: 60s
     restart: unless-stopped
