  # Species List Web App
# Species List Web App
services:
  species-list:
    container_name: la_species-list
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    image: {{ docker_registry | default('') }}{% if docker_registry %}/{% endif %}specieslist-webapp:{{ species_list_version | default('latest') }}
    volumes:
      - {{ data_dir }}/specieslist-webapp:/data/specieslist-webapp
{% include '_i18n_volumes.yml.j2' %}
    environment:
      TZ: {{ server_tz | default('UTC') }}
      JAVA_OPTS: ${SPECIES_LISTS_JAVA_OPTS}
    expose:
      - 8080
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
    depends_on:
{% if i18n.enabled and i18n.strategy == 'volume' and i18n.volume.source == 'init-container' %}
      i18n-init:
        condition: service_completed_successfully
{% endif %}
{% if enable_mysql | default(false) | bool %}
      mysql:
        condition: service_healthy
{% endif %}
{% if 'cas' in services_enabled %}
      cas:
        condition: service_healthy
      userdetails:
        condition: service_healthy
      apikey:
        condition: service_healthy
      cas-management:
        condition: service_healthy
{% endif %}
    healthcheck:
      test: ["CMD", "sh", "-c", "curl --fail --silent http://localhost:8080/actuator/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
    restart: unless-stopped

