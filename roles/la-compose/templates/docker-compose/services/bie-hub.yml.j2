  # BIE Hub - Species search frontend
services:
  bie-hub:
    image: {{ docker_registry | default('') }}{% if docker_registry %}/{% endif %}ala-bie-hub:{{ bie_hub_version | default('latest') }}
    container_name: la_bie-hub
    profiles: [app-core, full]
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    volumes:
      - {{ data_dir }}/ala-bie-hub:/data/ala-bie-hub
      # Bind the config subdir EXPLICITLY (not only via the parent above). The
      # ala-bie-hub image declares a VOLUME on /data/ala-bie-hub/config, so with
      # just the parent bind Docker overlays an EMPTY anonymous volume there and the
      # container sees no config -> "Unable to process file:.../config/languages.json"
      # (the host dir IS populated by the bie-hub role; it's a mount shadow, not a
      # missing/deleted file). An explicit bind on the exact VOLUME path overrides
      # the anonymous volume. Same pattern as la-pipelines (binds each subdir).
      - {{ data_dir }}/ala-bie-hub/config:/data/ala-bie-hub/config
      - {{ data_dir }}/ala-bie-hub/logs:/var/log/tomcat9
{% include '_i18n_volumes.yml.j2' %}
    restart: unless-stopped
    expose:
      - 8080
    environment:
      TZ: {{ server_tz | default('UTC') }}
      JAVA_OPTS: ${BIE_HUB_JAVA_OPTS}
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
    healthcheck:
      # Liveness only: la home GSP (/) da 500 por un NPE de messageSource del war
      # desplegado (PluginAwareResourceBundleMessageSource.getMergedProperties); el war
      # upstream con ExtendedPluginAwareResourceBundleMessageSource lo arregla. Cuando se
      # suba esa imagen, migrar a "/" u otra página real. /actuator (200, lista _links)
      # prueba que el contexto Spring arrancó y sirve HTTP. No hay /actuator/health (404).
      test: ["CMD", "sh", "-c", "curl --fail --silent http://localhost:8080/actuator || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
