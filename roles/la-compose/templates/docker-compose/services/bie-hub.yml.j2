  # BIE Hub - Species search frontend
services:
  bie-hub:
    image: {% set svc_reg = bie_hub_registry | default(docker_registry | default('')) %}{{ svc_reg }}{% if svc_reg %}/{% endif %}ala-bie-hub:{{ bie_hub_version | default('latest') }}
    container_name: la_bie-hub
    profiles: [app-core, full]
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    depends_on:
      # Order-independent: wait until branding actually serves before bie-hub boots and
      # caches the commonui header/footer (else g:applyLayout NPE -> 500). Cross-host safe
      # (branding may live on another host); see infrastructure/wait-for-branding.yml.
      wait-for-branding:
        condition: service_completed_successfully
    volumes:
      - {{ data_dir }}/ala-bie-hub:/data/ala-bie-hub
      # Explicit bind of the config subdir (also reachable via the parent bind above;
      # kept defensively, same pattern as la-pipelines). The config files are populated
      # on the host by the bie-hub role. The container runs as uid 1000, so config
      # READABILITY is ensured separately by config-dir-ensure (tasks/main.yml) which
      # recurse-chowns /data/ala-bie-hub/config to the container uid — languages.json /
      # charts.json are copied by the role as root:root 0640 otherwise.
      - {{ data_dir }}/ala-bie-hub/config:/data/ala-bie-hub/config
      - {{ data_dir }}/ala-bie-hub/logs:/var/log/tomcat9
{% include '_i18n_volumes.yml.j2' %}
    restart: unless-stopped
    expose:
      - 8080
    environment:
      TZ: {{ server_tz | default('UTC') }}
      JAVA_OPTS: ${BIE_HUB_JAVA_OPTS}
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
    healthcheck:
      # Liveness only: la home GSP (/) da 500 por un NPE de messageSource del war
      # desplegado (PluginAwareResourceBundleMessageSource.getMergedProperties); el war
      # upstream con ExtendedPluginAwareResourceBundleMessageSource lo arregla. Cuando se
      # suba esa imagen, migrar a "/" u otra página real. /actuator (200, lista _links)
      # prueba que el contexto Spring arrancó y sirve HTTP. No hay /actuator/health (404).
      test: ["CMD", "sh", "-c", "curl --fail --silent http://localhost:8080/actuator || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
