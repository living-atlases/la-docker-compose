# Logger Service
services:
  logger-service:
    image: {% set svc_reg = logger_service_registry | default(docker_registry | default('')) %}{{ svc_reg }}{% if svc_reg %}/{% endif %}logger-service:{{ logger_service_version | default('latest') }}
    container_name: {{ logger_service_docker_host | default('la_logger-service') }}
    profiles: [app-core, full]
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    restart: unless-stopped
    expose:
      - {{ logger_service_port | default('8080') }}
    environment:
      TZ: {{ server_tz | default('UTC') }}
      JAVA_OPTS: {{ logger_service_java_opts | default('-Xmx1g -Xms1g') }}
      SERVER_CONTEXT_PATH: {{ logger_context_path | default('/logger-service') }}
    # Image CMD hardcodes -Xmx2g (ignores JAVA_OPTS -> Exit 137 OOM) and
    # -Dspring.config.name=application,application-local-config, which never loads
    # the role-generated logger-config.properties -> datasource falls back to
    # localhost -> "Connection refused". Override to honor JAVA_OPTS and add the
    # logger-config name (mirrors image-service).
    command: ["/bin/sh", "-c", "exec java $$JAVA_OPTS -Xss512k -Djava.awt.headless=true -Dlogging.config=/data/logger-service/config/logback.xml -Dspring.config.additional-location=/data/logger-service/config/ -Dspring.config.name=application,application-local-config,logger-config -jar /opt/atlas/$$APP_ARTIFACT/app.jar"]
    volumes:
      # Role writes config to {data_dir}/logger/config; image CMD reads /data/logger-service/config.
      - {{ data_dir }}/logger/config:/data/logger-service/config
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
    # logger boots straight into a MySQL connection; without this gate it starts
    # before la_mysql accepts connections and dies with "Connection refused".
    # Only when mysql is co-located on this host: a remote mysql is not in this
    # compose file, so the gate would abort the up; remote => omit, converge by retry.
{% if datastore_endpoints.get('mysql', {}).get('colocated', false) %}
    depends_on:
      mysql:
        condition: service_healthy
{% endif %}
    # App serves at ROOT context (SERVER_CONTEXT_PATH is ignored by the image); nginx
    # proxies /service/logger/* -> :8080/service/logger/*. /service/logger/reasons returns
    # 200 only when the MySQL datasource is up, so it doubles as a DB-connectivity probe.
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:{{ logger_service_port | default('8080') }}/service/logger/reasons"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
