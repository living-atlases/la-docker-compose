# API Key Service
services:
  apikey:
    container_name: la_apikey
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    image: {{ docker_registry | default('') }}{% if docker_registry %}/{% endif %}apikey:{{ apikey_version | default('latest') }}
    volumes:
      - {{ data_dir }}/apikey:/data/apikey
      # - {{ docker_compose_data_dir }}/var-log-atlas/apikey:/var/log/atlas/apikey
{% include '_i18n_volumes.yml.j2' %}
    environment:
      TZ: {{ server_tz | default('UTC') }}
      JAVA_OPTS: ${APIKEY_JAVA_OPTS}
    expose:
      - {{ apikey_port | default('9002') }}
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
    depends_on:
{% if i18n.enabled and i18n.strategy == 'volume' and i18n.volume.source == 'init-container' %}
      i18n-init:
        condition: service_completed_successfully
{% endif %}
{% if enable_mysql | default(false) | bool %}
      mysql:
        condition: service_healthy
{% endif %}
      cas:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "sh", "-c", "curl --fail --silent http://localhost:{{ apikey_port | default('9002') }}/apikey/actuator/health || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
    restart: unless-stopped


