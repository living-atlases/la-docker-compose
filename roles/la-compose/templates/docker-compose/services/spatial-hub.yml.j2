# Spatial Hub - spatial portal frontend (consumes spatial-service)
services:
  spatial-hub:
    image: {% set svc_reg = spatial_hub_registry | default(docker_registry | default('')) %}{{ svc_reg }}{% if svc_reg %}/{% endif %}spatial-hub:{{ spatial_hub_version | default('latest') }}
    container_name: {{ spatial_docker_host | default('la_spatial-hub') }}
    profiles: [app-core, full]
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    volumes:
      # Role (ala-install/spatial-hub) writes config to {{ data_dir }}/spatial-hub/config
      # (spatial-hub-config.yml, menu/view-config.json, system-message.json); the image reads
      # /data/spatial-hub/config. config-dir-ensure recurse-chowns it to the container uid.
      - {{ data_dir }}/spatial-hub/config:/data/spatial-hub/config
{% if (use_branding | default(false) | bool) and (spatial_hub_skin_layout | default('portal')) == 'spatial-layout' %}
      # Living Atlas Spatial skin layout generated by base-branding (dist/spatial/views/), shipped
      # in the branding volume. Opt-in via spatial_hub_skin_layout=spatial-layout (default 'portal'
      # so an old branding never breaks this); generate-compose.yml verifies the branding actually
      # ships app/spatial/spatial-layout.gsp before deploy, so this mount only runs when it exists.
      # spatial-hub's BootStrap loads external layouts from /data/spatial-hub/views/layouts. The
      # layout is a plain navbar-default that reuses the commonui/ala styles already in the WAR's
      # application.css, so NO external assets mount is needed. The branding volume root IS the dist
      # root, so the subpath is spatial/views. Requires Docker Engine >= 26 (volume subpath). For
      # older Docker or cross-host branding, instead copy dist/spatial/views into
      # {{ data_dir }}/spatial-hub/views and bind-mount it.
      - type: volume
        source: la_branding-assets
        target: /data/spatial-hub/views
        read_only: true
        volume:
          subpath: spatial/views
{% endif %}
{% include '_i18n_volumes.yml.j2' %}
    restart: unless-stopped
    expose:
      - {{ spatial_hub_port | default('8080') }}
    environment:
      TZ: {{ server_tz | default('UTC') }}
      JAVA_OPTS: ${SPATIAL_JAVA_OPTS}
    # The baked image CMD hardcodes spring.config.name=application,application-local-config and
    # ignores $JAVA_OPTS, so the role-generated spatial-hub-config.yml is never loaded. Override
    # the command to add the spatial-hub-config name (mirrors logger/image/alerts). -Dlogging.config
    # points at the shipped Logback xml: the 3.x image is Spring Boot + Logback, but the role only
    # ships a legacy log4j.properties, and Logback aborts boot on it ("Unexpected filename
    # extension") — the crash loop reason. (see spatial-logback.xml, deployed by main.yml.)
    command: ["/bin/sh", "-c", "exec java $$JAVA_OPTS -Xss512k -Djava.awt.headless=true -Dlogging.config=/data/spatial-hub/config/spatial-logback.xml -Dspring.config.additional-location=/data/spatial-hub/config/ -Dspring.config.name=application,application-local-config,spatial-hub-config -jar /opt/atlas/$$APP_ARTIFACT/app.war"]
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
    # spatial-hub talks to spatial-service over HTTP; no depends_on (cross-host safe, converge
    # by retry — spatial-service may live on another host and lazy-connects anyway).
    healthcheck:
      # Liveness: spatial-hub is deployed at ROOT (spatial_hub_context_path=/). Accept 2xx/3xx/4xx
      # (server up) and fail on refused/5xx.
      test: ["CMD-SHELL", "curl -s -o /dev/null -w '%{http_code}' http://localhost:{{ spatial_hub_port | default('8080') }}/ | grep -qvE '^(000|5)'"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 120s
