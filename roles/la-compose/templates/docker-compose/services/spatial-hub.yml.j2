# Spatial Hub - spatial portal frontend (consumes spatial-service)
services:
{% if spatial_skin_active | default(false) | bool %}
  # Stage the built Spatial skin layout (spatial-layout.gsp) into the host-local views dir that
  # spatial-hub bind-mounts. The branding-builder image serves the built gsp via the branding nginx,
  # but Docker named volumes are per-host: on a multihost deploy the la_branding-assets volume is
  # populated only where branding-init runs and is EMPTY on the spatial-hub host. Every ALA hub
  # already reaches branding cross-host over HTTP (see wait-for-branding); do the same here and fetch
  # the gsp instead of mounting the (possibly empty) volume subpath. Gated by wait-for-branding so the
  # asset is actually being served (HTTP 200) first. Runs as root to write the bind dir; the 0644 file
  # is world-readable by spatial-hub (uid {{ docker_container_uid | default(1000) }}).
  spatial-skin-init:
    container_name: la_spatial-skin-init
    profiles: [app-core, full]
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
    image: curlimages/curl:8.11.1
    user: root
    depends_on:
      wait-for-branding:
        condition: service_completed_successfully
    networks:
      default: {}
      {{ docker_network | default('internal') }}: {}
    environment:
      TZ: {{ server_tz | default('UTC') }}
      BRANDING_URL: "{{ header_and_footer_baseurl | default('https://' ~ (branding_url | default('branding')) ~ (branding_path | default('/brand-2023'))) }}"
    entrypoint: ["sh", "-c"]
    command:
      - |
        base="$${BRANDING_URL%/}"
        gsp="$$base/spatial/views/layouts/spatial-layout.gsp"
        mkdir -p /output/layouts
        echo "spatial-skin-init: fetching $$gsp"
        n=0
        while true; do
          if curl -fsSk --max-time 10 -o /output/layouts/spatial-layout.gsp "$$gsp" \
             && [ -s /output/layouts/spatial-layout.gsp ]; then
            echo "spatial-skin-init: staged spatial-layout.gsp ($$(wc -c < /output/layouts/spatial-layout.gsp) bytes)"
            exit 0
          fi
          n=$$((n + 1))
          if [ "$$n" -ge 30 ]; then
            echo "spatial-skin-init: giving up after $$n tries; spatial-hub will start without the skin" >&2
            exit 0
          fi
          echo "spatial-skin-init: not ready, retry $$n in 3s"
          sleep 3
        done
    volumes:
      - {{ data_dir }}/spatial-hub/views:/output
    restart: "no"
{% endif %}
  spatial-hub:
    image: {% set svc_reg = spatial_hub_registry | default(docker_registry | default('')) %}{{ svc_reg }}{% if svc_reg %}/{% endif %}spatial-hub:{{ spatial_hub_version | default('latest') }}
    container_name: {{ spatial_docker_host | default('la_spatial-hub') }}
    profiles: [app-core, full]
    extra_hosts: {{ docker_extra_hosts_dict | default({}) | to_json }}
{% if spatial_skin_active | default(false) | bool %}
    depends_on:
      # Start only after la_spatial-skin-init has staged spatial-layout.gsp into the views bind below,
      # so the external-views resolver finds the layout on first boot (else skin.layout=spatial-layout
      # renders against a missing layout -> 500). Same-host services only; spatial-skin-init is defined
      # above in this file, gated on the identical condition.
      spatial-skin-init:
        condition: service_completed_successfully
{% endif %}
    volumes:
      # Role (ala-install/spatial-hub) writes config to {{ data_dir }}/spatial-hub/config
      # (spatial-hub-config.yml, menu/view-config.json, system-message.json); the image reads
      # /data/spatial-hub/config. config-dir-ensure recurse-chowns it to the container uid.
      - {{ data_dir }}/spatial-hub/config:/data/spatial-hub/config
{% if spatial_skin_active | default(false) | bool %}
      # Living Atlas Spatial skin layout (dist/spatial/views/, base-branding), staged host-locally to
      # {{ data_dir }}/spatial-hub/views by the "Deploy Spatial Portal skin views" task in main.yml.
      # Opt-in via spatial_hub_skin_layout=spatial-layout (default 'portal' so an old branding never
      # breaks this); generate-compose.yml verifies the branding actually ships the built GSP before
      # deploy, so this mount only runs when it exists. spatial-hub's BootStrap loads external layouts
      # from /data/spatial-hub/views/layouts; the layout reuses the commonui/ala styles already in the
      # WAR's application.css, so NO external assets mount is needed.
      #
      # This is a HOST-LOCAL bind, NOT the la_branding-assets volume subpath: Docker named volumes are
      # per-host, so on a multihost deploy the branding volume is populated only where branding-init
      # runs and is EMPTY on the spatial-hub host — the subpath mount would then start against an empty
      # dir and the layout would 500. The staging copy makes this work single-host AND cross-host.
      - {{ data_dir }}/spatial-hub/views:/data/spatial-hub/views:ro
{% endif %}
{% include '_i18n_volumes.yml.j2' %}
    restart: unless-stopped
    expose:
      - {{ spatial_hub_port | default('8080') }}
    environment:
      TZ: {{ server_tz | default('UTC') }}
      JAVA_OPTS: ${SPATIAL_JAVA_OPTS}
    # The baked image CMD hardcodes spring.config.name=application,application-local-config and
    # ignores $JAVA_OPTS, so the role-generated spatial-hub-config.yml is never loaded. Override
    # the command to add the spatial-hub-config name (mirrors logger/image/alerts). -Dlogging.config
    # points at the shipped Logback xml: the 3.x image is Spring Boot + Logback, but the role only
    # ships a legacy log4j.properties, and Logback aborts boot on it ("Unexpected filename
    # extension") — the crash loop reason. (see spatial-logback.xml, deployed by main.yml.)
    command: ["/bin/sh", "-c", "exec java $$JAVA_OPTS -Xss512k -Djava.awt.headless=true -Dlogging.config=/data/spatial-hub/config/spatial-logback.xml -Dspring.config.additional-location=/data/spatial-hub/config/ -Dspring.config.name=application,application-local-config,spatial-hub-config -jar /opt/atlas/$$APP_ARTIFACT/app.war"]
    networks:
      default: {}
      {{ docker_network | default('internal') }}:
    # spatial-hub talks to spatial-service over HTTP; no depends_on (cross-host safe, converge
    # by retry — spatial-service may live on another host and lazy-connects anyway).
    healthcheck:
      # Liveness: spatial-hub is deployed at ROOT (spatial_hub_context_path=/). Accept 2xx/3xx/4xx
      # (server up) and fail on refused/5xx.
      test: ["CMD-SHELL", "curl -s -o /dev/null -w '%{http_code}' http://localhost:{{ spatial_hub_port | default('8080') }}/ | grep -qvE '^(000|5)'"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 120s
