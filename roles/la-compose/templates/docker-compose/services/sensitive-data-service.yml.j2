services:
   sensitive-data-service:
     container_name: la_sensitive_data_service
     profiles: [app-core, full]
     image: {{ docker_registry | default('') }}{% if docker_registry %}/{% endif %}ala-sensitive-data-server:{{ sensitive_data_docker_tag | default('latest') }}
     ports:
       - "{{ sensitive_data_service_port }}:9189"
       - "{{ sensitive_data_admin_port }}:9190"
     environment:
       - JAVA_OPTS=-Xmx2g -Xms1g
       - SENSITIVE_DATA_SERVICE_JAVA_OPTS=-Xmx2g -Xms1g
     volumes:
       - "{{ data_dir }}/lucene/namematching-nm:/data/lucene/namematching-nm:ro"
       - "{{ data_dir }}/sds:/data/sds:ro"
       - "{{ data_dir }}/biocache/layers:/data/biocache/layers:ro"
       # El contenedor lee la config en .../ala-sensitive-data-service/config (la app dropwizard
       # falla con FileNotFoundException si se monta en .../ala-sensitive-data-server/config).
       # La imagen se llama -server pero el path de config que espera es -service.
       - "{{ data_dir }}/ala-sensitive-data-service/config:/data/ala-sensitive-data-service/config:ro"
     networks:
       default: {}
       {{ docker_network | default('internal') }}:
     healthcheck:
       test: ["CMD", "curl", "--fail", "--silent", "http://localhost:9190/healthcheck"]
       interval: 30s
       timeout: 10s
       retries: 3
       start_period: 60s
     restart: unless-stopped
